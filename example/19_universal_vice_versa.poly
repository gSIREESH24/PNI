python {
    print("\n--- Registering Cross-Language Logic ---")
    def py_multiply(x):
        return x * 2
    export_function("py_multiply", py_multiply)
    js_src = "poly_export_function('js_add_py', (x) => { return call_bridge('py_multiply', x) + 5; }, 'int');"
}
javascript {
    const js_add_py = (x) => {
        return call_bridge("py_multiply", x) + 5;
    };
    poly_export_function("js_add_py", js_add_py, "int");
    console.log("[JS] Registered fn: js_add_py (calls python)");
}
c {
    const char* c_source = 
        "long long c_func(long long x) {"
        "    char args[64];"
        "    sprintf(args, \"[%lld]\", x);"
        "    return call_bridge_i(\"js_add_py\", args) + 100;"
        "}";
    int main() {
        export_bridge_function("c_func", c_source, "int");
        printf("[C] Registered fn: c_func (calls JS)\n");
        return 0;
    }
}
cpp {
    const char* cpp_source = 
        "long long cpp_func(long long x) {"
        "    return call_bridge_i(\"c_func\", \"[\" + std::to_string(x) + \"]\") + 1000;"
        "}";
    int main() {
        export_bridge_function("cpp_func", cpp_source, "int");
        std::cout << "[C++] Registered fn: cpp_func (calls C)\n";
        return 0;
    }
}
java {
    class Main {
        public static void main(String[] args) {
            String javaSource = 
                "public static long java_func(long x) { " +
                "    return (Long)call_bridge(\"cpp_func\", x) + 10000; " +
                "}";
            export_bridge_function("java_func", javaSource, "int");
            System.out.println("[Java] Registered fn: java_func (calls C++)");
        }
    }
}
python {
    print("\n--- Universal Vice-Versa Execution ---")
    initial_val = 10
    print(f"Starting chain with value {initial_val}...")
    final_result = call("java_func", initial_val)
    print(f"Result from Java: {final_result}")
    print(f"Expected formula: (((((10 * 2) + 5) + 100) + 1000) + 10000) = 11125")
    if final_result == 11125:
        print("\n[SUCCESS] UNIVERSAL JNI EQUIVALENT SUCCESSFUL!")
    else:
        print("\n[FAILED] CHAIN FAILED!")
}
