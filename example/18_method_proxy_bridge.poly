python {
    class Counter:
        def __init__(self, initial):
            self.value = initial
        def increment(self, amount):
            self.value += amount
            return self.value
        def get_value(self):
            return self.value
    my_counter = Counter(10)
    handle_id = store_object(my_counter)
    export("bridge_counter", {"__handle__": handle_id})
    export("bridge_counter_handle", handle_id)
    print(f"[Python] Exported Counter with handle: {handle_id}, initial = {my_counter.value}")
}
js {
    let counter = get_global("bridge_counter");
    console.log("[JS] Calling counter.increment(5)");
    let res = counter.increment(5);
    console.log("[JS] Result: " + res);
}
c {
    int main() {
        long long hnd = bridge_counter_handle;
        printf("[C] Calling counter.increment(10) on handle %lld\n", hnd);
        long long res = call_method_i(hnd, "increment", "[10]");
        printf("[C] Result: %lld\n", res);
        return 0;
    }
}
cpp {
    int main() {
        long long hnd = bridge_counter_handle;
        std::cout << "[C++] Calling counter.increment(10) on handle " << hnd << std::endl;
        long long res = call_method_i(hnd, "increment", "[10]");
        std::cout << "[C++] Result: " << res << std::endl;
        return 0;
    }
}
java {
    class Main {
        public static void main(String[] args) {
            long hnd = (long) get_global("bridge_counter_handle");
            System.out.println("[Java] Calling counter.increment(10) on handle " + hnd);
            Object res = call_method(hnd, "increment", 10);
            System.out.println("[Java] Result: " + res);
        }
    }
}
python {
    print(f"[Python] Final counter value is: {my_counter.get_value()}")
}
