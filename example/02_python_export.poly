global {
    seed = 7
}
python {
    py_int    = seed * 10
    py_float  = seed * 1.5
    py_bool   = seed > 5
    py_string = f"Python computed from seed={seed}"
    export("py_int",    py_int)
    export("py_float",  py_float)
    export("py_bool",   py_bool)
    export("py_string", py_string)
    print(f"[Python] Exported int    = {py_int}")
    print(f"[Python] Exported float  = {py_float}")
    print(f"[Python] Exported bool   = {py_bool}")
    print(f"[Python] Exported string = {py_string}")
}
javascript {
    console.log("[JS] py_int    = " + get_global("py_int"));
    console.log("[JS] py_float  = " + get_global("py_float"));
    console.log("[JS] py_bool   = " + get_global("py_bool"));
    console.log("[JS] py_string = " + get_global("py_string"));
}
c {
    int main() {
        printf("[C] py_int    = %lld\n",  py_int);
        printf("[C] py_float  = %.2f\n",  py_float);
        printf("[C] py_bool   = %s\n",    py_bool ? "true" : "false");
        printf("[C] py_string = %s\n",    py_string);
        return 0;
    }
}
java {
    class Main {
        public static void main(String[] args) {
            System.out.println("[Java] py_int    = " + py_int);
            System.out.println("[Java] py_float  = " + py_float);
            System.out.println("[Java] py_bool   = " + py_bool);
            System.out.println("[Java] py_string = " + py_string);
        }
    }
}
