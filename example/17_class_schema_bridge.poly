python {
    class Point:
        def __init__(self, x, y, label="unlabeled"):
            self.x = x
            self.y = y
            self.label = label
    export_class("Point", Point, fields={
        "x": "float", 
        "y": "float",
        "label": "str"
    })
    print("[Python] Registered 'Point' schema (x: float, y: float, label: str)")
}
js {
    let p_js = new Point(10.5, 20.25, "JS Point");
    poly_export('p_js', p_js);
    console.log("[JS] Created Point object:", p_js);
}
c {
    int main() {
        Point p_c;
        p_c.x = 100.0;
        p_c.y = 200.0;
        p_c.label = "C Point";
        export_value_Point("p_c", p_c);
        printf("[C] Exported Point: x=%.1f y=%.1f label='%s'\n", p_c.x, p_c.y, p_c.label);
        return 0;
    }
}
cpp {
    int main() {
        Point p_cpp;
        p_cpp.x = 3.14159;
        p_cpp.y = 2.71828;
        p_cpp.label = "C++ Point";
        export_value("p_cpp", p_cpp);
        std::cout << "[C++] Exported Point: " << p_cpp.label << std::endl;
        return 0;
    }
}
java {
    class Main {
        public static void main(String[] args) {
            Point p_java = new Point(-1.0, -2.0, "Java Point");
            export_value("p_java", p_java);
            System.out.println("[Java] Exported Point: " + p_java.label);
        }
    }
}
python {
    print()
    print("--- Bridge Captured Objects ---")
    def hydrate(data):
        return Point(data['x'], data['y'], data['label'])
    def show(name):
        d = get_global(name)
        obj = hydrate(d)
        print(f"[{name}] -> Point(x={obj.x}, y={obj.y}, label=\"{obj.label}\")")
    show('p_js')
    show('p_c')
    show('p_cpp')
    show('p_java')
}
