global {
    n = 2
}
python {
    import math
    py_cubed = n ** 3
    export("py_cubed", py_cubed)
    print(f"[Python] {n}^3 = {py_cubed}")
}
javascript {
    const py_cubed = get_global("py_cubed");
    const js_scaled = py_cubed * 12.5;
    poly_export("js_scaled", js_scaled);
    console.log("[JS] " + py_cubed + " * 12.5 = " + js_scaled);
}
c {
    int main() {
        long long c_int = (long long)js_scaled;
        printf("[C] floor(%.1f) = %lld\n", js_scaled, c_int);
        export_value("c_int", c_int);
        return 0;
    }
}
cpp {
    int main() {
        long long cpp_squared = c_int * c_int;
        std::cout << "[C++] " << c_int << " * " << c_int << " = " << cpp_squared << std::endl;
        export_value("cpp_squared", cpp_squared);
        return 0;
    }
}
java {
    class Main {
        public static void main(String[] args) {
            double java_sqrt = Math.sqrt(cpp_squared);
            System.out.printf("[Java] sqrt(%d) = %.1f%n", cpp_squared, java_sqrt);
            export_value("java_sqrt", java_sqrt);
            export_value("chain_summary",
                "2 -> 8 -> 100 -> 100 -> 10000 -> " + (long)java_sqrt);
        }
    }
}
python {
    result  = get_global("java_sqrt")
    summary = get_global("chain_summary")
    print(f"[Python Block 2] Final result = {result}")
    print(f"[Python Block 2] Chain: {summary}")
}
