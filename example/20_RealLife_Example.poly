python {
    import urllib.request, json, time, random
    print("\n=======================================================")
    print("        POLYGLOT END-TO-END WEB APP DASHBOARD          ")
    print("=======================================================")
    
    print("\n[1/4] PYTHON_BLOCK: Reaching out to Public Live APIs...")
    
    # 1. Fetch real live Bitcoin price from CoinDesk API
    url = "https://api.coindesk.com/v1/bpi/currentprice.json"
    req = urllib.request.Request(url, headers={'User-Agent': 'Mozilla/5.0'})
    
    try:
        with urllib.request.urlopen(req) as response:
            data = json.loads(response.read().decode())
            live_price = data["bpi"]["USD"]["rate_float"]
            last_updated = data["time"]["updated"]
    except Exception as e:
        live_price = 65000.0
        last_updated = "Live Sync Failed - Using Offline Data"

    print(f"      -> Fetched Live Bitcoin Price: ${live_price}")
    print("[1/4] PYTHON_BLOCK: Simulating 1,000 historical trade ticks...")
    
    # 2. Generate 1,000 historical prices to simulate a data-heavy payload
    prices = []
    p = live_price
    for tick in range(1000):
        prices.append(str(round(p, 2)))
        p = p * (1.0 + random.uniform(-0.005, 0.005))
        
    prices_csv = ",".join(prices)

    # 3. Export to Polyglot Runtime Memory
    export("live_price", live_price)
    export("last_updated", last_updated)
    export("prices_csv", prices_csv)
    export("tick_count", 1000)
}

cpp {
    #include <iostream>
    #include <sstream>
    #include <vector>
    #include <cmath>
    #include <string>
    
    int main() {
        std::cout << "\n[2/4] CPP_BLOCK:    Taking " << tick_count << " heavy data points." << std::endl;
        std::cout << "                    Running native C++ Quantitative ML Computations..." << std::endl;
        
        std::string raw = prices_csv;
        std::vector<double> prices;
        std::stringstream ss(raw);
        std::string item;
        
        // Parse CSV data generated by Python
        while (std::getline(ss, item, ',')) {
            prices.push_back(std::stod(item));
        }
        
        // C++ Math: Calculate Moving Average
        double sum = 0;
        for(double p : prices) sum += p;
        double mean = sum / prices.size();
        
        // C++ Math: Calculate Variance / Volatility Index
        double variance = 0;
        for(double p : prices) variance += (p - mean) * (p - mean);
        variance /= prices.size();
        double volatility = std::sqrt(variance);
        
        // C++ Math: Projected Next Price Step Model
        double momentum = prices.back() - prices[prices.size() - 2];
        double forecast = prices.back() + (momentum * 2.5);
        
        std::cout << "      -> Computed Market Mean   : $" << mean << std::endl;
        std::cout << "      -> Computed Volatility    : $" << volatility << std::endl;
        
        // Export highly-processed metrics back to Runtime
        export_value("btc_mean", mean);
        export_value("btc_volatility", volatility);
        export_value("btc_forecast", forecast);
        return 0;
    }
}

java {
    class Main {
        public static void main(String[] args) {
            System.out.println("\n[3/4] JAVA_BLOCK:   Enterprise Logger formatting the Final Immutable Object...");
            
            String reportId = "TXN-" + System.currentTimeMillis();
            
            // Java excels at strict string formatting and Enterprise audit trails
            String auditTrail = String.format(
                "Audit [%s]: Live=%.2f, Mean=%.2f, Volatility=%.2f, Forecast=%.2f",
                reportId, live_price, btc_mean, btc_volatility, btc_forecast
            );
            
            System.out.println("      -> Signed Trail: " + auditTrail);
            
            export_value("report_id", reportId);
            export_value("audit_trail", auditTrail);
        }
    }
}

javascript {
    console.log("\n[4/4] JS_BLOCK:     Booting up Local Web Server to render Web App...");
    
    // JS Native HTTP module! It blocks the runtime so it stays alive indefinitely
    const http = require('http');
    
    // Grab all injected data from the Polyglot global scope
    const price = get_global("live_price");
    const updated = get_global("last_updated");
    const mean = get_global("btc_mean");
    const vol = get_global("btc_volatility");
    const forecast = get_global("btc_forecast");
    const audit = get_global("audit_trail");
    
    // JS is perfect for building Web Frontends! HTML + CSS 
    const html = `
    <!DOCTYPE html>
    <html lang="en">
    <head>
        <meta charset="UTF-8">
        <title>Polyglot Live AI Dashboard</title>
        <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;500;700&display=swap" rel="stylesheet">
        <style>
            body { 
                font-family: 'Poppins', sans-serif; background: #0f172a; color: white; display: flex; 
                justify-content: center; align-items: center; min-height: 100vh; margin: 0; 
            }
            .dashboard { background: rgba(30, 41, 59, 0.8); padding: 50px; border-radius: 20px; box-shadow: 0 20px 50px rgba(0,0,0,0.5); backdrop-filter: blur(10px); border: 1px solid rgba(255,255,255,0.1); width: 650px; text-align: center; }
            h1 { color: #38bdf8; margin-top: 0; font-size: 2.2em; text-shadow: 0 0 20px rgba(56, 189, 248, 0.4); }
            p.subtitle { color: #94a3b8; margin-bottom: 30px; font-size: 1.1em; }
            .grid { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 30px; }
            .card { background: #0f172a; padding: 25px; border-radius: 12px; border: 1px solid #334155; }
            .card span { display: block; font-size: 0.9em; color: #94a3b8; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 5px; }
            .card strong { display: block; font-size: 2em; color: #10b981; }
            .card.live { grid-column: 1 / -1; margin-bottom: 5px;}
            .card.live strong { color: #fbbf24; font-size: 3em; text-shadow: 0 0 20px rgba(251, 191, 36, 0.3); }
            .card.forecast strong { color: #f43f5e; }
            .footer { background: #020617; padding: 20px; border-radius: 8px; font-size: 0.85em; color: #64748b; font-family: monospace; line-height: 1.5; }
        </style>
    </head>
    <body>
        <div class="dashboard">
            <h1>Polyglot AI Analysis Engine</h1>
            <p class="subtitle">Python (API) &rarr; C++ (Math Core) &rarr; Java (Audit) &rarr; JS (Web App)</p>
            
            <div class="card live">
                <span>Live Public API Metric</span>
                <strong>$${price.toFixed(2)}</strong>
            </div>

            <div class="grid">
                <div class="card">
                    <span>C++ Processed Core</span>
                    <strong>$${mean.toFixed(2)}</strong>
                </div>
                <div class="card forecast">
                    <span>Algorithm Forecast</span>
                    <strong>$${forecast.toFixed(2)}</strong>
                </div>
            </div>

            <div class="footer">
                [SECURE AUDIT RECORD]<br>${audit}<br><br>
                [TIMESTAMP]<br>${updated}
            </div>
        </div>
    </body>
    </html>
    `;
    
    // Spin up an actual HTTP listener!
    const server = http.createServer((req, res) => {
        res.writeHead(200, { 'Content-Type': 'text/html' });
        res.end(html);
    });
    
    // Serve on port 8080!
    server.listen(8080, () => {
        console.log("\\n=======================================================");
        console.log("🚀 SUCCESS! Node.js Web Server is live and serving the frontend!");
        console.log("👉 OPEN YOUR BROWSER AND GO TO: http://localhost:8080");
        console.log("   (Press Ctrl+C in your terminal to stop the polyglot server)");
        console.log("=======================================================\n");
    });
}
